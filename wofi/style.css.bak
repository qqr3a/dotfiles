@import url("file:///home/yousef/.config/wofi/colors.css");


@define-color mauve  @color6;
@define-color red  @color9;
@define-color lavender  @color7;
@define-color text  @color9;
@keyframes fadeIn {
    0% {
    }
    100% {
    }
}

* {
    all:unset;
    font-family: 'CodeNewRoman Nerd Font Mono', monospace;
    font-size: 15px;
    outline: none;
    border: none;
    text-shadow:none;
    background-color:transparent;
}

window {
    all:unset;
    padding: 15px;
    border-radius: 0px;
    background-color: alpha(@color8,.5);
}
#inner-box {
    margin: 2px;
    padding: 5px
    border: none;
}
#outer-box {    
    border: none;
}
#scroll {
    margin: 0px;
    padding: 10px;
    border: none;
}
#input {
    all:unset;
    margin-left:10px;
    margin-right:10px;
    margin-top:10px;
    padding:10px;
    border: none;
    outline: none;
    color: @text;
    box-shadow: 1px 1px 5px rgba(0,0,0, .5);
    border-radius:10;
    background-color: alpha(@color8,.2);
}
#input image {
    border: none;
    color: @red;
    padding-right:10px;
}
#input * {
    border: none;
    outline: none;
}

#input:focus {
    outline: none;
    border: none;

    border-radius:10;
}
#text {
    margin: 5px;
    border: none;
    color: @text;
    outline:none;
}
#entry {
    border: none;
    margin: 5px;
    padding: 5px;
}
#entry arrow {
    border: none;
    color: @lavender;

}
#entry:selected {
    box-shadow: 1px 1px 5px alpha(@color13, 1);
    border: none;
    border-radius: 10px;
    background-color:alpha(@background,.6);
}
#entry:selected #text {
    color: @mauve;
}
#entry:drop(active) {
    background-color: @lavender !important;
}